# =============================================================================
# Cool AI Harness — environment template.
# Copy to `.env` and fill in. All values are optional unless noted.
# =============================================================================

# --- App ---
APP_NAME=Cool AI Harness
ENVIRONMENT=development       # development | production
DEBUG=true
# CORS origins (comma-separated). "*" allows all (fine for local dev).
CORS_ORIGINS=*

# --- Database ---
# SQLite by default (file created automatically). For PostgreSQL use:
#   postgresql+psycopg://user:pass@host:5432/harness
DATABASE_URL=sqlite:///./data/harness.db

# --- Security ---
# Fernet key for encrypting stored provider API keys at rest.
# Generate one with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRET_KEY=CHANGE_ME
# Single-user bearer token for MVP (empty disables the auth check).
API_TOKEN=

# --- Default LLM provider (MVP) ---
# openai | openrouter | deepseek | groq | ollama | local | anthropic
DEFAULT_PROVIDER=openai
DEFAULT_MODEL=gpt-4o-mini
# Base URL — override for OpenRouter/DeepSeek/Groq/Ollama, e.g.:
#   OpenRouter:  https://openrouter.ai/api/v1
#   DeepSeek:    https://api.deepseek.com/v1
#   Groq:        https://api.groq.com/openai/v1
#   Ollama:      http://localhost:11434/v1
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Telegram (Фаза 5) ---
TELEGRAM_BOT_TOKEN=
