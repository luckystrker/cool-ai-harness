# =============================================================================
# Cool AI Harness — environment template.
# Copy to `.env` and fill in. All values are optional unless noted.
# =============================================================================

# --- App ---
APP_NAME=Cool AI Harness
ENVIRONMENT=development       # development | production
DEBUG=true
# CORS origins (comma-separated). "*" allows all (fine for local dev).
# Defaults cover the Vite dev server (5173) and preview (4173).
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173

# --- Database ---
# SQLite by default (file created automatically). For PostgreSQL use:
#   postgresql+psycopg://user:pass@host:5432/harness
DATABASE_URL=sqlite:///./data/harness.db

# --- Security ---
# Fernet key for encrypting stored provider API keys at rest.
# Generate one with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRET_KEY=CHANGE_ME
# Single-user bearer token for MVP (empty disables the auth check).
API_TOKEN=

# --- Env-only LLM credentials (dev / test fallback) ---
# Primary config is the Providers UI (stored encrypted in the DB). These env
# vars are only used when no Provider row exists yet (local dev, tests).
# Pick the backend by setting the matching key:
#   ANTHROPIC_API_KEY  -> native Anthropic Messages API
#   OPENAI_API_KEY     -> OpenAI-compatible at OPENAI_BASE_URL
# Base URL — override for OpenRouter/DeepSeek/Groq/Ollama, e.g.:
#   OpenRouter:  https://openrouter.ai/api/v1
#   DeepSeek:    https://api.deepseek.com/v1
#   Groq:        https://api.groq.com/openai/v1
#   Ollama:      http://localhost:11434/v1
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
# Native Anthropic (Claude) Messages API.
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_API_KEY=

# --- Agent run limits (Фаза 1.5 §1) ---
AGENT_MAX_ITERATIONS=10
# AGENT_MAX_TOTAL_TOKENS=
# AGENT_MAX_COST_USD=
# AGENT_RUN_TIMEOUT_S=

# --- Provider resilience (Фаза 1.5 §5) ---
# Retries (with exponential backoff + jitter) and a per-provider circuit
# breaker for LLM calls. A second active Provider row with IS_FALLBACK=true
# serves as the backup model when the primary is unavailable (configured via
# the UI / API, not here).
PROVIDER_MAX_RETRIES=3
PROVIDER_RETRY_BASE_DELAY_S=0.5
PROVIDER_RETRY_MAX_DELAY_S=30.0
PROVIDER_CIRCUIT_FAILURE_THRESHOLD=5
PROVIDER_CIRCUIT_RESET_S=60.0

# --- Cost budgets (Фаза 1.5 §5) ---
# Behavior defaults. Per-window USD limits (daily/weekly/monthly) are set in
# the Budgets UI; these only govern the alert threshold and block behavior.
BUDGET_ALERT_THRESHOLD_PCT=80.0
BUDGET_BLOCK_ON_EXCEED=true

# --- Telegram (Фаза 5) ---
TELEGRAM_BOT_TOKEN=
